# Database (copy to .env and update credentials)
DATABASE_URL=postgresql://artifactforge:<your-password>@localhost:5432/artifactforge

# LLM Configuration
# Set these to control which provider and model the pipeline uses.
# If not set, provider is auto-detected from which API keys are present.
# LLM_PROVIDER=ollama
# LLM_MODEL=kimi-k2.5:cloud

# LLM Provider API Keys (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama (local models)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=kimi-k2.5:cloud

# Optional: Web Search
TAVILY_API_KEY=

# Additional Research APIs (optional)
PERPLEXITY_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=

# Context7 - Optional (higher rate limits with API key)
CONTEXT7_API_KEY=

# Application
LOG_LEVEL=INFO
ENVIRONMENT=development
