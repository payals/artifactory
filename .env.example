# Database (copy to .env and update credentials)
DATABASE_URL=postgresql://artifactforge:<your-password>@localhost:5432/artifactforge

# LLM Configuration
# Set these to control which provider and model the pipeline uses.
# If not set, provider is auto-detected from which API keys are present.
# LLM_PROVIDER=ollama
# LLM_MODEL=deepseek-v3.2:cloud

# Multi-model routing (optional per-tier overrides)
# When set, agents use tier-specific models instead of LLM_MODEL.
# Precision tier: intent parsing, evidence classification, verification, adversarial review
# PRECISION_LLM_MODEL=deepseek-v3.2:cloud
# Writing tier: drafting, polishing, analysis, content strategy
# WRITING_LLM_MODEL=qwen3.5:cloud
# Speed tier: research planning, arbitration, visual pipeline
# SPEED_LLM_MODEL=gemini-3-flash-preview:cloud

# LLM Provider API Keys (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=deepseek-v3.2:cloud

# Optional: Web Search
TAVILY_API_KEY=

# Additional Research APIs (optional)
PERPLEXITY_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=

# Context7 - Optional (higher rate limits with API key)
CONTEXT7_API_KEY=

# Application
LOG_LEVEL=INFO
ENVIRONMENT=development
